# ── LLM Configuration ──────────────────────────────────────
# Default model for single-run mode
DEFAULT_MODEL=llama-3.1-8b
# Default provider (cerebras, groq, together, deepseek, mistral)
DEFAULT_PROVIDER=cerebras
# Temperature for LLM inference (0 = deterministic)
LLM_TEMPERATURE=0

# ── Message Broker (Redpanda — Kafka-compatible) ──────────
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# ── Kafka Topics ───────────────────────────────────────────
KAFKA_TOPIC_NETWORK=network_events
KAFKA_TOPIC_DEVICE=device_events
KAFKA_TOPIC_SENSOR=sensor_data
KAFKA_TOPIC_ALERTS=cyber_alerts
KAFKA_TOPIC_NORMALIZED=normalized_events
KAFKA_CONSUMER_GROUP=cybersecurity_agents

# ── Redis (Shared State Store) ─────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Arena Configuration ────────────────────────────────────
# Detection window in seconds (sliding window buffer)
DETECTION_WINDOW_SECONDS=30
# Number of runs per scenario for Pass@k evaluation
PASS_AT_K=3
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ── Application Ports ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
